# ==============================
# СКОПИРУЙ ЭТОТ ФАЙЛ В .env
# И ЗАПОЛНИ СВОИМИ ЗНАЧЕНИЯМИ
# ==============================

# База данных PostgreSQL
DATABASE_URL=postgresql://toyshop_user:toyshop_pass@localhost:5432/toyshop_db

# Секретный ключ для JWT (придумай любую длинную случайную строку)
SECRET_KEY=your-super-secret-key-change-this-in-production-minimum-32-chars

# Алгоритм подписи токенов (не меняй)
ALGORITHM=HS256

# Время жизни токена в минутах (60 = 1 час)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Папка для загрузки файлов (изображения товаров)
UPLOAD_DIR=uploads

# Режим отладки (True = разработка, False = продакшн)
DEBUG=True
